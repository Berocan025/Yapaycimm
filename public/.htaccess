# diziportal - DG SPORTS .htaccess | Developer: DiziPortal.Com
<IfModule mod_rewrite.c>
RewriteEngine On
# Serve existing files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
# Fallback to index.php
RewriteRule ^ index.php [L]
</IfModule>

# MIME types for HLS
AddType application/vnd.apple.mpegurl .m3u8
AddType video/mp2t .ts
AddType video/mp4 .mp4

# CORS headers for static assets (note: source stream CORS is controlled by the source server)
<IfModule mod_headers.c>
  Header set Access-Control-Allow-Origin "*"
  Header set Access-Control-Allow-Methods "GET, OPTIONS"
  Header set Access-Control-Allow-Headers "Range, Origin, X-Requested-With, Content-Type, Accept"
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/* "access plus 30 days"
  ExpiresByType video/* "access plus 7 days"
</IfModule>