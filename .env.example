# DG SPORTS - Environment Configuration
# Developer: DiziPortal.Com
# Copy this file to .env and configure your settings

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME="DG SPORTS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yoursite.com
APP_TIMEZONE=Europe/Istanbul
APP_KEY=your-secret-key-change-this-to-random-string

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=dg_sports
DB_USERNAME=your_username
DB_PASSWORD=your_password

# ===========================================
# CACHE CONFIGURATION
# ===========================================
CACHE_DRIVER=file
CACHE_TTL=3600

# ===========================================
# REDIS CONFIGURATION (Optional)
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# MAIL CONFIGURATION (Optional)
# ===========================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@dgsports.com
MAIL_FROM_NAME="DG SPORTS"

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=info
LOG_MAX_FILES=30

# ===========================================
# SECURITY SETTINGS
# ===========================================
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE=true
SESSION_HTTP_ONLY=true

# ===========================================
# UPLOAD SETTINGS
# ===========================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,svg,webp

# ===========================================
# THIRD-PARTY SERVICES (Optional)
# ===========================================
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
CLOUDFLARE_ZONE_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ===========================================
# SOCIAL MEDIA LINKS
# ===========================================
TELEGRAM_URL=
INSTAGRAM_URL=
TWITTER_URL=
TIKTOK_URL=
YOUTUBE_URL=
FACEBOOK_URL=

# ===========================================
# PERFORMANCE SETTINGS
# ===========================================
GZIP_COMPRESSION=true
BROWSER_CACHE=true
CDN_ENABLED=false
CDN_URL=

# ===========================================
# FEATURE FLAGS
# ===========================================
MAINTENANCE_MODE=false
REGISTRATION_ENABLED=false
COMMENTS_ENABLED=false
RATING_ENABLED=true
ANALYTICS_ENABLED=true

# ===========================================
# API SETTINGS (Future Use)
# ===========================================
API_RATE_LIMIT=60
API_TIMEOUT=30